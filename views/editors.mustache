{{>header}}

{{>navigation}}

<div class="row">
  <div class="leftcolumn">
    <div class="card">
      <h2>Editors</h2>
      <p>Only editors should be able to view this page!</p>
      <p style="color:red;">{{ error }}</p>

      <h3>Users</h3>
      <table border="1" cellpadding="8">
        <tr>
          <th>Username</th>
          <th>Password</th>
          <th>Level</th>
        </tr>
        {{#users}}
        <tr>
          <td>{{username}}</td>
          <td>{{password}}</td>
          <td>{{level}}</td>
        </tr>
        {{/users}}
      </table>

      <br />

      <h3>Articles</h3>
      <table border="1" cellpadding="8">
        <tr>
          <th>Title</th>
          <th>Username</th>
        </tr>
        {{#articles}}
        <tr>
          <td>{{title}}</td>
          <td>{{username}}</td>
        </tr>
        {{/articles}}
      </table>
    </div>
  </div>

  {{>sidebar}}

</div>

{{>footer}}